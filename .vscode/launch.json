{
  // F5 로 실행할 구성들.
  // 사이드바의 'Run and Debug' 패널에서 드롭다운으로 선택.
  // breakpoint 도 디버거 attach 후 자동 동작.
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Probe — list",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build:Probe",
      "program": "${workspaceFolder}/src/Forge.Probe/bin/Debug/net8.0-windows/Forge.Probe.exe",
      "args": ["list"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "stopAtEntry": false
    },
    {
      "name": "Probe — insert",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build:Probe",
      "program": "${workspaceFolder}/src/Forge.Probe/bin/Debug/net8.0-windows/Forge.Probe.exe",
      "args": ["insert"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "stopAtEntry": false
    },
    {
      "name": "Forge.UI",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build:UI",
      "program": "${workspaceFolder}/src/Forge.UI/bin/Debug/net8.0-windows/Forge.UI.exe",
      "args": [],
      "cwd": "${workspaceFolder}",
      "console": "internalConsole",
      "stopAtEntry": false
    }
  ]
}
