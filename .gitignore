# =====================================================================
# Sentinel-Forge .gitignore
# 본격 개발 개시 (2026-04-26) — 산출물 중 git tracking 대상만 남김
# =====================================================================

# ─────────────────────────────────────────────────────────────────────
# 환경변수·자격증명 (절대 커밋 금지)
# ─────────────────────────────────────────────────────────────────────
.env
.env.*
*.local
secrets.*
credentials.*
.mcp.json.local

# .mcp.json 은 커밋 유지 (MariaDB 비밀번호 포함하나 로컬 dev 전용 hdbuser)
# 만약 자격증명 분리 필요 시 .mcp.json.local 로 override

# ─────────────────────────────────────────────────────────────────────
# Claude Code 로컬 / OS / IDE
# ─────────────────────────────────────────────────────────────────────
.claude/
.DS_Store
Thumbs.db
.idea/
# .vscode/ 는 통째 무시하지만 — F5 디버그 / 빌드 태스크 / 권장 확장 4종은
# 팀(=다른 개발 PC) 과 공유. 개인 설정은 settings.json 에 두면 무시됨.
.vscode/*
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/extensions.json
!.vscode/zip-publish.ps1
*.swp

# ─────────────────────────────────────────────────────────────────────
# Python (Forge 본체 — STAGE 1·2·3 + GUI)
# ─────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
build.log
dist/
.venv/
.venv-build/
venv/
env/
.python-version

# 테스트·품질 도구 캐시
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# Jupyter
.ipynb_checkpoints/

# ─────────────────────────────────────────────────────────────────────
# .NET (C# 포팅 — src/, tests/Forge.*)
# ─────────────────────────────────────────────────────────────────────
bin/
obj/
*.user
*.suo
*.userprefs
*.cache
.vs/
publish/
*.binlog
# 솔루션 파일은 커밋 유지 — 무시 안 함
# !Forge.sln

# ─────────────────────────────────────────────────────────────────────
# Node.js (dev-support MCP 전용)
# ─────────────────────────────────────────────────────────────────────
node_modules/
dev-support/hwp-api-mcp/dist/
dev-support/tool2-spec-mcp/dist/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─────────────────────────────────────────────────────────────────────
# HWP 산출물·작업 파일
# ─────────────────────────────────────────────────────────────────────
*.bak
*.gul
~$*
tests/output/
tests/_tmp/
tests/samples/*.hwpx
tests/samples/*.hwp
out/
tmp/

# ─────────────────────────────────────────────────────────────────────
# 빌드·배포 산출물
# ─────────────────────────────────────────────────────────────────────
*.spec
release/
*.zip
# *.exe 는 reference/tool2/금감원 오피스 프로그램.exe 등 외부 자산 ignore 용
*.exe

# ─────────────────────────────────────────────────────────────────────
# reference/ — 개발 참조용 자료 통째 ignore
# ─────────────────────────────────────────────────────────────────────
# tool1·tool2 분석 자료, 한컴 공식 PDF, pycdc 클론 등 모두 개발자 로컬에만.
# 분석 결과 중 본 프로젝트 운영에 필요한 사양은 spec/ 또는 코드 주석으로 흡수.
reference/

# ─────────────────────────────────────────────────────────────────────
# tool2-spec-mcp seed (extract_to_sql.py 로 재생성 — 큰 SQL 파일)
# ─────────────────────────────────────────────────────────────────────
dev-support/tool2-spec-mcp/scripts/seed.sql
